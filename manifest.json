{
  "manifest_version": 3,
  "name": "Dwar Sarthi",
  "version": "1.0.0",
  "description": "Personal speed dial synced with GitHub",

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },

  "permissions": [
    "storage",
    "alarms"
  ],

  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },

  "host_permissions": [
    "https://api.github.com/*"
  ],

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "settings.html",
    "default_title": "Dwar Sarthi Settings"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src https://api.github.com; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'"
  }
}
